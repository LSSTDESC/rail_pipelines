#!/bin/bash
# QOS (https://docs.nersc.gov/jobs/policy/#selecting-a-queue)
#SBATCH --qos=debug
#
#SBATCH --time=5
#SBATCH --nodes=2
#SBATCH --ntasks-per-node=4
#SBATCH --constraint=cpu

# The following line was from an example at (https://docs.nersc.gov/jobs/examples/)
# srun check-mpi.gnu.pm

# The following line was generated by $ ceci tmp_random_gauss.yml 
# OMP_NUM_THREADS=1  mpirun -n 2 python3 -m ceci rail.estimation.algos.random_gauss.RandomGaussEstimator   --input=validation_10gal.hdf5   --name=rg_estimate   --config=tmp_random_gauss_config.yml   --output=./output_rg_estimate.hdf5 --mpi

# The above runs successfully :)  see slurm-20237079.out:
# Executing stage: RandomGaussEstimator @ 2024-01-10 07:01:51.475062
# Inserting handle into data store.  input: validation_10gal.hdf5, rg_estimate
# Inserting handle into data store.  input: validation_10gal.hdf5, rg_estimate
# Process 0 running estimator on chunk 0 - 10
# Inserting handle into data store.  output_rg_estimate: inprogress_output_rg_estimate.hdf5, rg_estimate
# Stage complete: RandomGaussEstimator @ 2024-01-10 07:01:51.777038 took 0.01 minutes

# Some research:
# (https://stackoverflow.com/questions/43894608/use-of-omp-num-threads-1-for-python-multiprocessing) 
#   - Setting OMP_NUM_THREADS=1 basically turns off the OpenMP multi-threading, so each of your Python processes remains single-threaded.
# (https://www.open-mpi.org/doc/v4.0/man1/mpirun.1.php)
#   - mpirun -c, -n, --n, -np <#>
#     Run this many copies of the program on the given nodes. 
#     This option indicates that the specified file is an executable program and not an application context. 
#     If no value is provided for the number of copies to execute (i.e., neither the "-np" nor its synonyms are provided on the command line), Open MPI will automatically execute a copy of the program on each process slot. This feature, however, can only be used in the SPMD model and will return an error (without beginning execution of the application) otherwise. 

# With some modifications:
# Also update the .yml, _config.yml (chunk_size: 10000 -> 10, data now training not validation)
OMP_NUM_THREADS=2  mpirun -n 4 python3 -m ceci rail.estimation.algos.random_gauss.RandomGaussEstimator   --input=training_100gal.hdf5   --name=rg_estimate   --config=tmp_random_gauss_config.yml   --output=./output_rg_estimate.hdf5 --mpi

# RAIL Meet notes:
# OMP_NUM_THREADS is still kind of vague -> look this up in NERSC documention! they have maximums and it's different for each queue 
# Note Alex uses jobarrays, though that's not the kind of parallelization we need in this case. Apparently there's good docuemntation for this on NERSC
# Also note you can point to a single output file that will get rewritten - consider the pros and cons about overwriting things to reduce clutter, vs having ALL THE DATA
# And explore the sending an email on status change! -> you would specify this at the top, among the other SBATCH commands. There's documentation for this on NERSC
# Keep an eye on ntasks-per-node=128 -> maybe should lower this (default was 128), look into NERSC doc on limit for ntasks-per-node for debug (probably caps at 4 for debug)
#    Note that not on perlumutter, but other clusters require you to use 95% requested power or job is stopped
